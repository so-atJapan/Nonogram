{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Main",
            "request": "launch",
            "mainClass": "Nonogram.Main",
            "cwd": "${workspaceFolder}",
            "vmArgs": "--module-path \"lib\" --add-modules javafx.controls,javafx.fxml --enable-native-access=javafx.graphics,org.xerial.sqlitejdbc --sun-misc-unsafe-memory-access=allow",
            "env": {
                "PATH": "${workspaceFolder}/dll;${env:PATH}"
            }
        }
    ]
}